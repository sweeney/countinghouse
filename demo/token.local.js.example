// Local dev convenience for the demo pages. Copy this to token.local.js (which is
// gitignored) and paste a bearer token to auto-authenticate the demos without
// typing it into the page each time:
//
//   cp demo/token.local.js.example demo/token.local.js
//   # then edit token.local.js and paste a token from id.swee.net
//
// The demos read window.CH_DEV_TOKEN if present, otherwise fall back to a token
// pasted into the page's Connection settings (persisted in localStorage).
window.CH_DEV_TOKEN = 'PASTE_BEARER_TOKEN_HERE';
